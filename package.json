  "bugs": {
    "url": "https://github.com/wyre-technology/proofpoint-mcp/issues"
  },
  "homepage": "https://github.com/wyre-technology/proofpoint-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@types/node": "^25.9.2",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "semantic-release": "^25.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
